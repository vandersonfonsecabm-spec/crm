generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cliente {
  id              Int              @id @default(autoincrement())
  empresaId       Int
  empresaTenant   Empresa          @relation(fields: [empresaId], references: [id], onDelete: Restrict)
  nome            String
  telefone        String           @default("")
  email           String           @default("")
  empresa         String           @default("")
  interesse       String           @default("")
  status          String           @default("Lead")
  valor           Int              @default(0)
  origem          String           @default("Manual")
  favorito        Boolean          @default(false)
  quente          Boolean          @default(false)
  ultimoContato   Int              @default(0)
  proximoFollowUp String           @default("Hoje")
  tags            String           @default("[]")
  createdAt       DateTime         @default(now())
  notas           Nota[]
  acompanhamentos Acompanhamento[]

  @@index([empresaId])
  @@index([empresaId, status])
  @@index([empresaId, quente])
  @@index([empresaId, createdAt])
}

model Nota {
  id        Int      @id @default(autoincrement())
  empresaId Int
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Restrict)
  texto     String
  tipo      String   @default("nota")
  createdAt DateTime @default(now())
  clienteId Int
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([clienteId])
  @@index([empresaId, clienteId])
  @@index([empresaId, createdAt])
}

model CategoriaProduto {
  id        Int       @id @default(autoincrement())
  nome      String    @unique
  descricao String?
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  produtos  Produto[]
}

model Produto {
  id                 Int                   @id @default(autoincrement())
  nome               String
  codigo             String?               @unique
  descricao          String?
  categoriaId        Int?
  categoria          CategoriaProduto?     @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  unidadeMedida      String                @default("UN")
  quantidadeAtual    Decimal               @default(0)
  estoqueMinimo      Decimal               @default(0)
  precoCustoCentavos Int                   @default(0)
  precoVendaCentavos Int                   @default(0)
  ativo              Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  movimentacoes      MovimentacaoEstoque[]

  @@index([categoriaId])
  @@index([ativo])
}

model MovimentacaoEstoque {
  id                  Int                     @id @default(autoincrement())
  produtoId           Int
  produto             Produto                 @relation(fields: [produtoId], references: [id])
  tipo                TipoMovimentacaoEstoque
  quantidade          Decimal
  quantidadeAnterior  Decimal
  quantidadePosterior Decimal
  motivo              String?
  observacao          String?
  createdAt           DateTime                @default(now())

  @@index([produtoId])
  @@index([tipo])
  @@index([createdAt])
}

model Acompanhamento {
  id          Int                      @id @default(autoincrement())
  empresaId   Int
  empresa     Empresa                  @relation(fields: [empresaId], references: [id], onDelete: Restrict)
  clienteId   Int
  cliente     Cliente                  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  titulo      String
  descricao   String?
  dataHora    DateTime
  prioridade  PrioridadeAcompanhamento @default(MEDIA)
  status      StatusAcompanhamento     @default(PENDENTE)
  tipo        TipoAcompanhamento       @default(LIGACAO)
  responsavel String?
  concluidoEm DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([empresaId])
  @@index([clienteId])
  @@index([empresaId, clienteId])
  @@index([empresaId, dataHora])
  @@index([empresaId, status])
  @@index([empresaId, prioridade])
  @@index([empresaId, tipo])
}

model Empresa {
  id                         Int                         @id @default(autoincrement())
  nome                       String
  slug                       String                      @unique
  ativo                      Boolean                     @default(true)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  usuarios                   Usuario[]
  clientes                   Cliente[]
  notas                      Nota[]
  acompanhamentos            Acompanhamento[]
  integracoes                Integracao[]
  sincronizacoesIntegracao   SincronizacaoIntegracao[]
  errosIntegracao            ErroIntegracao[]
  produtosExternos           ProdutoExterno[]
  estoquesExternos           EstoqueExterno[]
  precosExternos             PrecoExterno[]
  condicoesPagamentoExternas CondicaoPagamentoExterna[]
  importacoesDados           ImportacaoDados[]
  oauthStatesIntegracao      IntegracaoOAuthState[]
  canaisIntegracao           CanalIntegracao[]
  contatosCanal              ContatoCanal[]
  conversasCanal             ConversaCanal[]
  mensagensCanal             MensagemCanal[]
}

model Usuario {
  id                  Int               @id @default(autoincrement())
  empresaId           Int
  empresa             Empresa           @relation(fields: [empresaId], references: [id])
  nome                String
  email               String
  senhaHash           String
  papel               PapelUsuario      @default(VENDEDOR)
  ativo               Boolean           @default(true)
  ultimoLoginEm       DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  importacoesCriadas  ImportacaoDados[]
  oauthStatesIntegracao IntegracaoOAuthState[]

  @@unique([empresaId, email])
  @@index([empresaId])
  @@index([email])
  @@index([ativo])
}

model IntegracaoOAuthState {
  id         Int       @id @default(autoincrement())
  empresaId  Int
  empresa    Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuarioId  Int
  usuario    Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  provedor   String
  stateHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([empresaId])
  @@index([usuarioId])
  @@index([provedor])
  @@index([expiresAt])
}

model Integracao {
  id                        Int                       @id @default(autoincrement())
  empresaId                 Int
  empresa                   Empresa                   @relation(fields: [empresaId], references: [id])
  nome                      String
  tipo                      TipoIntegracao
  status                    StatusIntegracao          @default(PENDENTE)
  modo                      ModoIntegracao            @default(SOMENTE_LEITURA)
  configuracaoJson          String                    @default("{}")
  credenciaisCriptografadas String?
  ultimaSincronizacaoEm     DateTime?
  ultimoSucessoEm           DateTime?
  ultimoErroEm              DateTime?
  ativo                     Boolean                   @default(true)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  sincronizacoes            SincronizacaoIntegracao[]
  erros                     ErroIntegracao[]
  produtosExternos          ProdutoExterno[]
  estoquesExternos          EstoqueExterno[]
  precosExternos            PrecoExterno[]
  condicoesPagamento        CondicaoPagamentoExterna[]
  importacoes               ImportacaoDados[]

  @@index([empresaId])
  @@index([empresaId, status])
  @@index([empresaId, tipo])
  @@index([ativo])
}

model SincronizacaoIntegracao {
  id                Int                  @id @default(autoincrement())
  integracaoId      Int
  integracao        Integracao           @relation(fields: [integracaoId], references: [id], onDelete: Cascade)
  empresaId         Int
  empresa           Empresa              @relation(fields: [empresaId], references: [id])
  status            StatusSincronizacao  @default(PENDENTE)
  origem            OrigemSincronizacao  @default(MANUAL)
  iniciadaEm        DateTime             @default(now())
  finalizadaEm      DateTime?
  itensRecebidos    Int                  @default(0)
  itensProcessados  Int                  @default(0)
  itensComErro      Int                  @default(0)
  mensagemErro      String?
  metadadosJson     String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  erros             ErroIntegracao[]

  @@index([empresaId])
  @@index([integracaoId])
  @@index([status])
  @@index([origem])
  @@index([iniciadaEm])
}

model ErroIntegracao {
  id                   Int                      @id @default(autoincrement())
  empresaId            Int
  empresa              Empresa                  @relation(fields: [empresaId], references: [id])
  integracaoId         Int
  integracao           Integracao               @relation(fields: [integracaoId], references: [id], onDelete: Cascade)
  sincronizacaoId      Int?
  sincronizacao        SincronizacaoIntegracao? @relation(fields: [sincronizacaoId], references: [id], onDelete: SetNull)
  codigo               String
  mensagem             String
  detalhesSanitizados  String?
  resolvido            Boolean                  @default(false)
  createdAt            DateTime                 @default(now())
  resolvedAt           DateTime?

  @@index([empresaId])
  @@index([integracaoId])
  @@index([sincronizacaoId])
  @@index([resolvido])
  @@index([codigo])
}

model ProdutoExterno {
  id                 Int               @id @default(autoincrement())
  empresaId          Int
  empresa            Empresa           @relation(fields: [empresaId], references: [id])
  integracaoId       Int
  integracao         Integracao        @relation(fields: [integracaoId], references: [id], onDelete: Cascade)
  externalId         String
  sku                String?
  codigoBarras       String?
  nome               String
  descricao          String?
  categoria          String?
  marca              String?
  unidade            String?
  ativo              Boolean           @default(true)
  dadosOriginaisJson String?
  sincronizadoEm     DateTime          @default(now())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  estoques           EstoqueExterno[]
  precos             PrecoExterno[]

  @@unique([integracaoId, externalId])
  @@index([empresaId])
  @@index([integracaoId])
  @@index([sku])
  @@index([codigoBarras])
  @@index([nome])
  @@index([categoria])
}

model EstoqueExterno {
  id               Int             @id @default(autoincrement())
  empresaId        Int
  empresa          Empresa         @relation(fields: [empresaId], references: [id])
  integracaoId     Int
  integracao       Integracao      @relation(fields: [integracaoId], references: [id], onDelete: Cascade)
  produtoExternoId Int
  produtoExterno   ProdutoExterno  @relation(fields: [produtoExternoId], references: [id], onDelete: Cascade)
  localExternalId  String?
  localNome        String?
  quantidade       Decimal         @default(0)
  reservado        Decimal?
  disponivel       Decimal         @default(0)
  sincronizadoEm   DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([empresaId])
  @@index([integracaoId])
  @@index([produtoExternoId])
  @@index([localExternalId])
}

model PrecoExterno {
  id                        Int             @id @default(autoincrement())
  empresaId                 Int
  empresa                   Empresa         @relation(fields: [empresaId], references: [id])
  integracaoId              Int
  integracao                Integracao      @relation(fields: [integracaoId], references: [id], onDelete: Cascade)
  produtoExternoId          Int
  produtoExterno            ProdutoExterno  @relation(fields: [produtoExternoId], references: [id], onDelete: Cascade)
  tabela                    String?
  precoCentavos             Int
  precoPromocionalCentavos  Int?
  inicioPromocao            DateTime?
  fimPromocao               DateTime?
  sincronizadoEm            DateTime        @default(now())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  @@index([empresaId])
  @@index([integracaoId])
  @@index([produtoExternoId])
  @@index([tabela])
}

model CondicaoPagamentoExterna {
  id                  Int             @id @default(autoincrement())
  empresaId           Int
  empresa             Empresa         @relation(fields: [empresaId], references: [id])
  integracaoId        Int
  integracao          Integracao      @relation(fields: [integracaoId], references: [id], onDelete: Cascade)
  externalId          String
  nome                String
  parcelas            Int?
  valorMinimoCentavos Int?
  ativo               Boolean         @default(true)
  sincronizadoEm      DateTime        @default(now())
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([integracaoId, externalId])
  @@index([empresaId])
  @@index([integracaoId])
  @@index([ativo])
}

model ImportacaoDados {
  id                 Int                @id @default(autoincrement())
  empresaId          Int
  empresa            Empresa            @relation(fields: [empresaId], references: [id])
  integracaoId       Int?
  integracao         Integracao?        @relation(fields: [integracaoId], references: [id], onDelete: SetNull)
  formato            FormatoImportacao
  status             StatusImportacao   @default(ENVIADO)
  nomeArquivo        String
  tamanhoBytes       Int
  hashArquivo        String
  tipoEntidade       String
  mapeamentoJson     String?
  totalLinhas        Int                @default(0)
  linhasValidas      Int                @default(0)
  linhasComErro      Int                @default(0)
  iniciadaEm         DateTime?
  finalizadaEm       DateTime?
  createdByUsuarioId Int
  createdByUsuario   Usuario            @relation(fields: [createdByUsuarioId], references: [id])
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  erros              ErroImportacao[]

  @@index([empresaId])
  @@index([integracaoId])
  @@index([createdByUsuarioId])
  @@index([status])
  @@index([formato])
  @@index([hashArquivo])
}

model ErroImportacao {
  id              Int             @id @default(autoincrement())
  importacaoId    Int
  importacao      ImportacaoDados @relation(fields: [importacaoId], references: [id], onDelete: Cascade)
  linha           Int?
  campo           String?
  codigo          String
  mensagem        String
  valorSanitizado String?
  createdAt       DateTime        @default(now())

  @@index([importacaoId])
  @@index([codigo])
}

model CanalIntegracao {
  id             Int              @id @default(autoincrement())
  empresaId      Int
  empresa        Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  tipo           TipoCanal
  nome           String
  chaveInterna   String
  status         StatusCanal      @default(MODO_TESTE)
  modoTeste      Boolean          @default(true)
  ativo          Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  contatos       ContatoCanal[]
  conversas      ConversaCanal[]
  mensagens      MensagemCanal[]

  @@unique([empresaId, chaveInterna])
  @@index([empresaId])
  @@index([empresaId, tipo])
  @@index([empresaId, ativo])
}

model ContatoCanal {
  id                 Int              @id @default(autoincrement())
  empresaId          Int
  empresa            Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  canalIntegracaoId  Int
  canalIntegracao    CanalIntegracao  @relation(fields: [canalIntegracaoId], references: [id], onDelete: Cascade)
  externalId         String
  telefoneNormalizado String?
  nome               String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  conversas          ConversaCanal[]

  @@unique([canalIntegracaoId, externalId])
  @@index([empresaId])
  @@index([canalIntegracaoId])
  @@index([empresaId, telefoneNormalizado])
}

model ConversaCanal {
  id                 Int              @id @default(autoincrement())
  empresaId          Int
  empresa            Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  canalIntegracaoId  Int
  canalIntegracao    CanalIntegracao  @relation(fields: [canalIntegracaoId], references: [id], onDelete: Cascade)
  contatoCanalId     Int
  contatoCanal       ContatoCanal     @relation(fields: [contatoCanalId], references: [id], onDelete: Cascade)
  status             StatusConversa   @default(ABERTA)
  chaveAberta        String?          @unique
  ultimaMensagemEm   DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  mensagens          MensagemCanal[]

  @@index([empresaId])
  @@index([canalIntegracaoId])
  @@index([contatoCanalId])
  @@index([status])
  @@index([ultimaMensagemEm])
}

model MensagemCanal {
  id                 Int                 @id @default(autoincrement())
  empresaId          Int
  empresa            Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  canalIntegracaoId  Int
  canalIntegracao    CanalIntegracao     @relation(fields: [canalIntegracaoId], references: [id], onDelete: Cascade)
  conversaCanalId    Int
  conversaCanal      ConversaCanal       @relation(fields: [conversaCanalId], references: [id], onDelete: Cascade)
  externalId         String
  direcao            DirecaoMensagem
  tipo               TipoMensagemCanal   @default(TEXTO)
  texto              String?
  status             StatusMensagem      @default(RECEBIDA)
  simulada           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([canalIntegracaoId, externalId])
  @@index([empresaId])
  @@index([canalIntegracaoId])
  @@index([conversaCanalId])
  @@index([status])
  @@index([createdAt])
}

enum TipoCanal {
  WHATSAPP_META
}

enum StatusCanal {
  MODO_TESTE
  INATIVO
}

enum DirecaoMensagem {
  ENTRADA
  SAIDA
}

enum StatusConversa {
  ABERTA
  ENCERRADA
}

enum StatusMensagem {
  RECEBIDA
  PROCESSADA
  PREPARADA
  ERRO
}

enum TipoMensagemCanal {
  TEXTO
  DESCONHECIDA
}

enum TipoMovimentacaoEstoque {
  ENTRADA
  SAIDA
  AJUSTE
}

enum StatusAcompanhamento {
  PENDENTE
  CONCLUIDO
  CANCELADO
}

enum PrioridadeAcompanhamento {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum TipoAcompanhamento {
  LIGACAO
  WHATSAPP
  EMAIL
  REUNIAO
  VISITA
  OUTRO
}

enum PapelUsuario {
  ADMIN
  GERENTE
  VENDEDOR
}

enum TipoIntegracao {
  BLING
  OMIE
  CONTA_AZUL
  TINY
  ALTERDATA
  CSV
  XLSX
  XML
  JSON
  CUSTOM
}

enum StatusIntegracao {
  PENDENTE
  ATIVA
  INATIVA
  ERRO
}

enum ModoIntegracao {
  SOMENTE_LEITURA
  LEITURA_ESCRITA
}

enum StatusSincronizacao {
  PENDENTE
  EXECUTANDO
  CONCLUIDA
  CONCLUIDA_COM_ERROS
  FALHOU
  CANCELADA
}

enum OrigemSincronizacao {
  MANUAL
  AGENDADA
  WEBHOOK
  IMPORTACAO
}

enum FormatoImportacao {
  CSV
  XLSX
  XML
  JSON
}

enum StatusImportacao {
  ENVIADO
  MAPEAMENTO_PENDENTE
  VALIDANDO
  PRONTO
  PROCESSANDO
  CONCLUIDO
  CONCLUIDO_COM_ERROS
  FALHOU
  CANCELADO
}
