generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cliente {
  id        Int      @id @default(autoincrement())
  nome      String
  telefone  String
  cidade    String
  estado    String
  tipo      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}